<UserControl x:Class="Barcoded_Warehouse_Stock_Tracking.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Actions -->
        <Border Grid.Column="0" Background="#16213E" CornerRadius="12" Padding="25" Margin="0,0,15,0">
            <StackPanel>
                <!-- Add Customer -->
                <TextBlock Text="👤  Yeni Müşteri Ekle" Foreground="#E94560" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <TextBox x:Name="txtName" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#E94560" Padding="10" VerticalContentAlignment="Center" Margin="0,0,0,10" Tag="Ad Soyad *"/>
                <TextBox x:Name="txtPhone" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#E94560" Padding="10" VerticalContentAlignment="Center" Margin="0,0,0,10" Tag="Telefon"/>
                <TextBox x:Name="txtEmail" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#E94560" Padding="10" VerticalContentAlignment="Center" Margin="0,0,0,15" Tag="E-posta"/>
                
                <Button Content="＋ Müşteri Ekle" Style="{StaticResource PrimaryButton}" Background="#2ecc71" Height="40" Margin="0,0,0,25" Click="BtnAdd_Click"/>
                
                <Border Height="1" Background="#2A3A5A" Margin="0,0,0,25"/>

                <!-- Add Collection -->
                <TextBlock Text="💰  Tahsilat İşlemi" Foreground="#3498db" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <ComboBox x:Name="cmbCustomer" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3498db" Margin="0,0,0,10" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="cmbMethod" Grid.Column="0" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3498db" Margin="0,0,10,0" SelectedIndex="0">
                        <ComboBoxItem Content="Cash"/>
                        <ComboBoxItem Content="Card"/>
                    </ComboBox>
                    <TextBox x:Name="txtAmount" Grid.Column="1" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3498db" Padding="10" VerticalContentAlignment="Center" Text="0"/>
                </Grid>

                <Button Content="✓ Tahsilatı Kaydet" Style="{StaticResource PrimaryButton}" Background="#3498db" Height="40" Click="BtnCollect_Click"/>
            </StackPanel>
        </Border>

        <!-- Right Panel: DataGrid -->
        <Border Grid.Column="1" Background="#16213E" CornerRadius="12" Padding="1">
            <DataGrid x:Name="dgvCustomers" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Ad Soyad" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="Bakiye (TL)" Binding="{Binding Balance, StringFormat=N2}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

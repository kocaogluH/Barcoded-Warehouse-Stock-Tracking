<UserControl x:Class="Barcoded_Warehouse_Stock_Tracking.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Panel -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Başlangıç" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                    <DatePicker x:Name="dtFrom" Width="130" Height="40"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Bitiş" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                    <DatePicker x:Name="dtTo" Width="130" Height="40"/>
                </StackPanel>

                <Button Grid.Column="2" Content="RAPORLARI YENİLE" Style="{StaticResource PrimaryButton}" Background="#3498db" Width="180" Height="40" VerticalAlignment="Bottom" Click="BtnRefreshSales_Click"/>

                <Button Grid.Column="4" Content="VERİTABANI YEDEKLE" Style="{StaticResource PrimaryButton}" Background="#7f8c8d" Width="180" Height="40" VerticalAlignment="Bottom" Click="BtnBackup_Click"/>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="15,10" Background="#1A1A2E" Margin="0,0,5,0" CornerRadius="8,8,0,0">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#16213E" />
                                        <Setter Property="Foreground" Value="#E94560"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="#B4B4C8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="📅 Günlük Satış">
                <Border Background="#16213E" CornerRadius="0,8,8,8" Padding="1">
                    <DataGrid x:Name="dgvDaily" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Day}" Width="*"/>
                            <DataGridTextColumn Header="Satış Adedi" Binding="{Binding SaleCount}" Width="*"/>
                            <DataGridTextColumn Header="Toplam Tutar (₺)" Binding="{Binding Total, StringFormat=N2}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="📦 Ürün Satışları">
                <Border Background="#16213E" CornerRadius="0,8,8,8" Padding="1">
                    <DataGrid x:Name="dgvProducts" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Barkod" Binding="{Binding Barcode}" Width="*"/>
                            <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Adet" Binding="{Binding Qty}" Width="*"/>
                            <DataGridTextColumn Header="Ciro (₺)" Binding="{Binding Total, StringFormat=N2}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="⚠ Stok Azalanlar">
                <Border Background="#16213E" CornerRadius="0,8,8,8" Padding="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15">
                            <TextBlock Text="Eşik Seviyesi:" Foreground="#B4B4C8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtThreshold" Text="5" Width="60" Height="30" Background="#232D4E" Foreground="White" BorderThickness="0" Padding="5" VerticalContentAlignment="Center" Margin="0,0,15,0"/>
                            <Button Content="🔄 Yenile" Style="{StaticResource PrimaryButton}" Background="#e74c3c" Width="100" Height="30" Click="BtnRefreshStock_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="dgvLowStock" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="10,0,10,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Barkod" Binding="{Binding Barcode}" Width="*"/>
                                <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Mevcut Stok" Binding="{Binding StockQty}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="💳 Cari Bakiye">
                <Border Background="#16213E" CornerRadius="0,8,8,8" Padding="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15">
                            <Button Content="🔄 Yenile" Style="{StaticResource PrimaryButton}" Background="#2ecc71" Width="100" Height="30" Click="BtnRefreshCust_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="dgvCustomers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="10,0,10,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Müşteri" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="*"/>
                                <DataGridTextColumn Header="E-Posta" Binding="{Binding Email}" Width="*"/>
                                <DataGridTextColumn Header="Bakiye (₺)" Binding="{Binding Balance, StringFormat=N2}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

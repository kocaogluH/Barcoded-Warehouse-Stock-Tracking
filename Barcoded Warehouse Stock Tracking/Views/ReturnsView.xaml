<UserControl x:Class="Barcoded_Warehouse_Stock_Tracking.Views.ReturnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Panel (Search) -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="12" Padding="25" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="↩  İade / İptal İşlemi" Foreground="#E94560" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>
                <TextBlock Text="Sorgulanacak Fiş / Satış No" Foreground="#B4B4C8" FontSize="14" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtSaleNo" Width="350" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3C5078" Padding="10" VerticalContentAlignment="Center" Margin="0,0,15,0" Tag="🔍 Fiş No Yazın..." KeyDown="txtSaleNo_KeyDown"/>
                    <Button Content="SATIŞI BUL" Style="{StaticResource PrimaryButton}" Background="#3498db" Width="130" Height="40" Click="BtnLoad_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Center DataGrid -->
        <Border Grid.Row="1" Background="#16213E" CornerRadius="12" Padding="1" Margin="0,0,0,15">
            <DataGrid x:Name="dgvReturns" AutoGenerateColumns="False" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Barkod" Binding="{Binding Barcode}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Ürün" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Fiyat" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Satılan" Binding="{Binding SoldQty}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="İade Edilen" Binding="{Binding ReturnedQty}" Width="100" IsReadOnly="True"/>
                    
                    <!-- Editable Column for Return Quantity -->
                    <DataGridTextColumn Header="İade Adet" Binding="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2ecc71"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="#232D4E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom Panel -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="12" Padding="25">
            <Grid>
                <TextBlock Text="ℹ  Sadece 'Completed' satışlardan iade yapılır. Kısmi iade desteklenir." Foreground="#B4B4C8" FontStyle="Italic" VerticalAlignment="Center"/>
                <Button Content="↩  İadeyi Kaydet (Stok Geri Al)" Style="{StaticResource PrimaryButton}" Background="#e67e22" Width="280" Height="50" HorizontalAlignment="Right" Click="BtnReturn_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

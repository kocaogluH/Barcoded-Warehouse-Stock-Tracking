<Window x:Class="Barcoded_Warehouse_Stock_Tracking.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Poseidon Yazılım - Ana Ekran" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="#16213E"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="45"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A3A5A"/>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E94560"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#232D4E"/>
                        <Setter Property="Foreground" Value="#B4B4C8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button Style -->
        <Style TargetType="Button" x:Key="SidebarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B4B4C8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="10,5">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1A2E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#232D4E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgDark}" CornerRadius="15" BorderBrush="#333" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource BgCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Branding -->
                    <StackPanel Grid.Row="0" Margin="20,30,20,30">
                        <TextBlock Text="POSEİDON" Foreground="{StaticResource AccentColor}" FontSize="24" FontWeight="Black" HorizontalAlignment="Center"/>
                        <TextBlock Text="YAZILIM" Foreground="White" FontSize="16" FontWeight="Light" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1">
                        <Button Content="📊  Dashboard" Style="{StaticResource SidebarButton}" Foreground="White" Background="#1A1A2E" Click="BtnDashboard_Click"/>
                        <Button Content="🛒  POS / Satış" Style="{StaticResource SidebarButton}" Click="BtnPos_Click"/>
                        <Button Content="👥  Müşteriler" Style="{StaticResource SidebarButton}" Click="BtnCustomers_Click"/>
                        <Button Content="↩️  İadeler" Style="{StaticResource SidebarButton}" Click="BtnReturns_Click"/>
                        <Button x:Name="btnReports" Content="📈  Raporlar" Style="{StaticResource SidebarButton}" Click="BtnReports_Click"/>
                    </StackPanel>

                    <!-- User Info & Logout -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock x:Name="lblUserInfo" Text="Hoş Geldiniz, Admin" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <Button Content="Çıkış Yap" Foreground="{StaticResource AccentColor}" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnLogout_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Grid Grid.Row="0" Margin="30,20,30,10">
                    <TextBlock Text="Dashboard İzleme Paneli" Foreground="White" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="—" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Click="BtnMinimize_Click" Cursor="Hand"/>
                        <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Margin="10,0,0,0" Click="BtnClose_Click" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- SPA Main Content Area -->
                <ContentControl x:Name="MainContent" Grid.Row="1" Margin="30,10,30,30" />
            </Grid>
        </Grid>
    </Border>
</Window>

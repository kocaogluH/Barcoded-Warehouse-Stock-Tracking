<UserControl x:Class="Barcoded_Warehouse_Stock_Tracking.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Panel -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="Hızlı Satış / POS" Foreground="#E94560" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Barkod" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtBarcode" Width="300" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3C5078" Padding="10" VerticalContentAlignment="Center" KeyDown="txtBarcode_KeyDown"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Adet" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtQty" Text="1" Width="80" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3C5078" Padding="10" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <Button Content="＋ EKLE" Style="{StaticResource PrimaryButton}" Width="120" Height="40" Background="#2ecc71" VerticalAlignment="Bottom" Click="BtnAdd_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Center DataGrid -->
        <Border Grid.Row="1" Background="#16213E" CornerRadius="12" Padding="1" Margin="0,0,0,15">
            <DataGrid x:Name="dgvCart" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Barkod" Binding="{Binding BarcodeSnapshot}" Width="150"/>
                    <DataGridTextColumn Header="Ürün" Binding="{Binding NameSnapshot}" Width="*"/>
                    <DataGridTextColumn Header="Fiyat (₺)" Binding="{Binding UnitPrice, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="Tutar (₺)" Binding="{Binding TotalPrice, StringFormat=N2}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom Panel -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Payment Options -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="İndirim (TL)" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                            <TextBox x:Name="txtDiscount" Text="0" Width="140" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3C5078" Padding="10" VerticalContentAlignment="Center" TextChanged="Payment_TextChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Nakit (Oto)" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                            <TextBox x:Name="txtCash" Text="0" Width="140" Height="40" Background="#1C2641" Foreground="#2ecc71" BorderBrush="#3C5078" Padding="10" FontWeight="Bold" IsReadOnly="True" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Kart" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                            <TextBox x:Name="txtCard" Text="0" Width="140" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3C5078" Padding="10" VerticalContentAlignment="Center" TextChanged="Payment_TextChanged"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Dış Fiş No" Foreground="#B4B4C8" FontSize="12" Margin="5,0,0,5"/>
                            <TextBox x:Name="txtSaleNo" Width="140" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3C5078" Padding="10" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Row="1">
                        <CheckBox x:Name="chkCustomer" Content="Veresiye" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" Checked="ChkCustomer_CheckedChanged" Unchecked="ChkCustomer_CheckedChanged"/>
                        <ComboBox x:Name="cmbCustomer" Width="295" Height="40" Background="#232D4E" Foreground="White" BorderBrush="#3C5078" IsEnabled="False" Margin="0,0,15,0"/>
                        <Button x:Name="btnCustomers" Content="Müşteriler" Width="140" Height="40" Background="#344982" Foreground="White" FontWeight="Bold" IsEnabled="False" BorderThickness="0" Cursor="Hand" Click="BtnCustomers_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Right Total Panel -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="GENEL TOPLAM" Foreground="#B4B4C8" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="lblTotal" Text="0,00 TL" Foreground="#E94560" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Content="SATIŞI TAMAMLA" Style="{StaticResource PrimaryButton}" Background="#2ecc71" Width="200" Height="50" FontSize="16" Click="BtnComplete_Click"/>
                    <CheckBox x:Name="chkAutoPrint" Content="Otomatik Fiş Yazdır" Foreground="#B4B4C8" FontSize="12" IsChecked="True" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

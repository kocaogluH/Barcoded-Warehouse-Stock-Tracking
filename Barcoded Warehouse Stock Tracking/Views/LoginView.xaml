<Window x:Class="Barcoded_Warehouse_Stock_Tracking.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Poseidon Yazılım - Giriş" Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <!-- Placeholder Styles removed because they were breaking input. -->
    </Window.Resources>

    <Border Background="{StaticResource BgDark}" CornerRadius="20" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <!-- Close Button -->
            <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="15" Background="Transparent" Foreground="{StaticResource TextMuted}" BorderThickness="0"
                    FontSize="16" Click="BtnClose_Click" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="#E94560" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                <!-- Logo PlaceHolder -->
                <Ellipse Width="120" Height="120" Margin="0,0,0,20" Fill="#232D4E" x:Name="elLogo" />

                <TextBlock Text="Poseidon Yazılım" Foreground="{StaticResource AccentColor}" 
                           FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="Depo &amp; Stok Yönetim Sistemi" Foreground="{StaticResource TextMuted}" 
                           FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,30" />

                <Border Background="{StaticResource BgCard}" CornerRadius="16" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Hesabınıza Giriş Yapın" Foreground="White" FontSize="18" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,0,0,20" />

                        <Grid Margin="0,0,0,15">
                            <TextBox x:Name="txtUser" Height="45" Tag="Kullanıcı Adı" FontSize="14" TextChanged="TxtUser_TextChanged"/>
                            <TextBlock x:Name="lblUserPlaceholder" Text="Kullanıcı Adı" VerticalAlignment="Center" Margin="12,0,0,0" 
                                       Foreground="{StaticResource TextMuted}" IsHitTestVisible="False" FontSize="14"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,25">
                            <PasswordBox x:Name="txtPass" Height="45" Tag="Şifre" FontSize="14" PasswordChanged="TxtPass_PasswordChanged"/>
                            <TextBlock x:Name="lblPassPlaceholder" Text="Şifre" VerticalAlignment="Center" Margin="12,0,0,0" 
                                       Foreground="{StaticResource TextMuted}" IsHitTestVisible="False" FontSize="14"/>
                        </Grid>

                        <Button Content="SİSTEME GİRİŞ YAP" Style="{StaticResource PrimaryButton}" 
                                Height="50" Click="BtnLogin_Click" IsDefault="True"/>

                        <TextBlock x:Name="lblError" Foreground="{StaticResource AccentColor}" 
                                   HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Text="© 2026 Poseidon Yazılım — Software &amp; Automation" Foreground="#646482" 
                       FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
        </Grid>
    </Border>
</Window>
